{
  "title": "Honeypot Dashboard",
  "uid": "honeypot-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "timezone": "browser",
  "tags": ["honeypot"],
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "SSH Attempts (24h)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=\"cowrie\"}[$__range]))",
          "queryType": "range",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["last"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "red"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}]}
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "HTTP Requests (24h)",
      "type": "stat",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=\"http-honeypot\"}[$__range]))",
          "queryType": "range",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["last"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "orange"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "orange", "value": null}]}
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Attacks Over Time",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 8},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(job) (count_over_time({job=~\"cowrie|http-honeypot\"}[$__interval]))",
          "queryType": "range",
          "legendFormat": "{{job}}"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"lineInterpolation": "smooth", "fillOpacity": 20}
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Top Attacking IPs",
      "type": "table",
      "gridPos": {"x": 0, "y": 12, "w": 8, "h": 8},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (src_ip) (count_over_time({job=~\"cowrie|http-honeypot\"} | json | src_ip != \"\" [$__range])))",
          "queryType": "instant",
          "legendFormat": "{{src_ip}}"
        }
      ],
      "options": {"sortBy": [{"displayName": "Attempts", "desc": true}]},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "transformations": [
        {"id": "labelsToFields", "options": {"mode": "columns"}},
        {"id": "merge", "options": {}},
        {"id": "organize", "options": {"renameByName": {"Value": "Attempts", "src_ip": "IP Address"}}}
      ]
    },
    {
      "id": 5,
      "title": "Top SSH Usernames",
      "type": "table",
      "gridPos": {"x": 8, "y": 12, "w": 8, "h": 8},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (username) (count_over_time({job=\"cowrie\"} | json | username != \"\" [$__range])))",
          "queryType": "instant",
          "legendFormat": "{{username}}"
        }
      ],
      "options": {"sortBy": [{"displayName": "Attempts", "desc": true}]},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "transformations": [
        {"id": "labelsToFields", "options": {"mode": "columns"}},
        {"id": "merge", "options": {}},
        {"id": "organize", "options": {"renameByName": {"Value": "Attempts", "username": "Username"}}}
      ]
    },
    {
      "id": 6,
      "title": "Top HTTP Paths Scanned",
      "type": "table",
      "gridPos": {"x": 16, "y": 12, "w": 8, "h": 8},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (path) (count_over_time({job=\"http-honeypot\"} | json | path != \"\" [$__range])))",
          "queryType": "instant",
          "legendFormat": "{{path}}"
        }
      ],
      "options": {"sortBy": [{"displayName": "Hits", "desc": true}]},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "transformations": [
        {"id": "labelsToFields", "options": {"mode": "columns"}},
        {"id": "merge", "options": {}},
        {"id": "organize", "options": {"renameByName": {"Value": "Hits", "path": "Path"}}}
      ]
    },
    {
      "id": 8,
      "title": "Attack Origins Map",
      "type": "geomap",
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 12},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"http-honeypot\"} | json | latitude != \"\" | longitude != \"\"",
          "queryType": "range"
        }
      ],
      "options": {
        "view": {"id": "zero", "lat": 0, "lon": 0, "zoom": 1},
        "controls": {"mouseWheelZoom": true, "showZoom": true, "showAttribution": true},
        "basemap": {"type": "default"},
        "layers": [
          {
            "type": "markers",
            "name": "Attacks",
            "config": {
              "style": {
                "size": {"fixed": 6},
                "color": {"fixed": "red"},
                "opacity": 0.8
              },
              "showLegend": true
            },
            "location": {
              "mode": "coords",
              "latitude": "latitude",
              "longitude": "longitude"
            },
            "tooltip": true
          }
        ]
      },
      "fieldConfig": {"defaults": {}, "overrides": []},
      "transformations": [
        {"id": "labelsToFields", "options": {"mode": "columns"}},
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {"targetField": "latitude", "destinationType": "number"},
              {"targetField": "longitude", "destinationType": "number"}
            ]
          }
        }
      ]
    },
    {
      "id": 7,
      "title": "Recent Events",
      "type": "logs",
      "gridPos": {"x": 0, "y": 32, "w": 24, "h": 10},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "expr": "{job=~\"cowrie|http-honeypot\"}",
          "queryType": "range",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "fieldConfig": {"defaults": {}, "overrides": []}
    }
  ]
}
